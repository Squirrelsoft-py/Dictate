# ─── Local ASR sidecar (onerahmet/whisper-asr-webservice) ─────────
# Leave empty to fall back to cloud providers
LOCAL_ASR_ENDPOINT=http://asr:9000

# ─── Admin provider defaults (overridable per upload) ────────────
ADMIN_ASR_PROVIDER=local
ADMIN_DIARIZATION_PROVIDER=local
ADMIN_LLM_PROVIDER=openai-compat

# ─── Cloud provider keys (only required if you use the cloud impl) ─
OPENAI_API_KEY=
GROQ_API_KEY=
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── OpenAI-compatible endpoint (MiniMax, Ollama, OpenRouter, etc.) ──
# Covers any service speaking the OpenAI Chat Completions schema
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# ─── Auth ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-please
BETTER_AUTH_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:3000

# ─── Storage ─────────────────────────────────────────────────────
DATA_DIR=/data
UPLOAD_MAX_BYTES=2147483648
UPLOAD_RETENTION_DAYS=0

# ─── Worker ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
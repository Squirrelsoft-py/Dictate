# =============================================================================
# Dictate — single combined environment file
# Copy to `.env` and edit. All keys are read by docker-compose.yml and the
# Dictate services (web, api, worker, redis, asr).
# =============================================================================

# ─── Ports (host-side) ─────────────────────────────────────────────────────
WEB_PORT=3000
API_PORT=3001
ASR_PORT=9000

# ─── Provider defaults (overridable per upload in the UI) ─────────────────
# Set these to `local` to use the bundled onerahmet/whisper-asr-webservice
# sidecar. Set to `openai-whisper`, `groq`, `deepgram`, `assemblyai`, or
# `openai-compatible` to use a cloud / external API instead.
ADMIN_ASR_PROVIDER=local
ADMIN_DIARIZATION_PROVIDER=local
ADMIN_LLM_PROVIDER=openai-compat

# ─── Local ASR sidecar (onerahmet/whisper-asr-webservice) ─────────────────
# Inside Docker, the asr service is reachable at http://asr:9000.
# If you're running the asr sidecar on another host, set this to that URL.
LOCAL_ASR_ENDPOINT=http://asr:9000

# Whisper model: tiny | base | small | medium | large-v3 | distil-large-v3
# large-v3 = best quality, slowest, ~3 GB download
# medium   = good balance, ~1.5 GB, recommended for CPU-only hosts
# small    = ~500 MB, fast
ASR_MODEL=large-v3

# ASR engine: openai_whisper | faster_whisper | whisper_cpp | insanely_fast
ASR_ENGINE=openai_whisper

# Run pyannote diarization inside the asr sidecar (true | false)
ASR_DIARIZATION=true

# ─── Cloud provider API keys ──────────────────────────────────────────────
# Fill only the ones you actually use. Leave blank to disable a provider.
OPENAI_API_KEY=
GROQ_API_KEY=
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── OpenAI-compatible endpoint ───────────────────────────────────────────
# Use this for MiniMax, Ollama (with its /v1 server), Groq, OpenRouter,
# Together, LocalAI, vLLM, LM Studio, or any other Chat Completions endpoint.
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# ─── Auth ─────────────────────────────────────────────────────────────────
# Generate a secret: `openssl rand -hex 32`
BETTER_AUTH_SECRET=change-me-please-change-me-please
# Public URL the browser uses to reach the API (the rewritten /api/* path)
BETTER_AUTH_URL=http://localhost:3001
# Origin the API allows CORS from (the web UI)
WEB_ORIGIN=http://localhost:3000

# ─── Storage ──────────────────────────────────────────────────────────────
DATA_DIR=/data
UPLOAD_MAX_BYTES=2147483648          # 2 GB
UPLOAD_RETENTION_DAYS=0              # 0 = keep forever

# ─── Redis (internal, the bundled redis service is used) ──────────────────
REDIS_URL=redis://redis:6379
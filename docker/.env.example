# Defaults so docker compose up works out of the box.
# Copy this to .env and edit values you want to change,
# or override per-stack in Dockge / Portainer / Cosmos UI.

WEB_PORT=3000
API_PORT=3001
ASR_PORT=9000

# Override these to use your own image registry or pinned tags.
# Defaults pull from GHCR.
WEB_IMAGE=ghcr.io/squirrelsoft-py/dictate-web:latest
API_IMAGE=ghcr.io/squirrelsoft-py/dictate-api:latest
WORKER_IMAGE=ghcr.io/squirrelsoft-py/dictate-worker:latest

# ASR sidecar image. Defaults to CPU tag. To enable GPU:
#   1. Set ASR_IMAGE=onerahmet/openai-whisper-asr-webservice:latest-gpu
#   2. Add the gpu override:  -f docker-compose.gpu.yml
ASR_IMAGE=onerahmet/openai-whisper-asr-webservice:latest

ADMIN_ASR_PROVIDER=local
ADMIN_DIARIZATION_PROVIDER=local
ADMIN_LLM_PROVIDER=openai-compat

LOCAL_ASR_ENDPOINT=http://asr:9000
ASR_MODEL=large-v3
ASR_ENGINE=openai_whisper
ASR_DIARIZATION=true

OPENAI_API_KEY=
GROQ_API_KEY=
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
ANTHROPIC_API_KEY=

OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

BETTER_AUTH_SECRET=change-me-please-change-me-please
BETTER_AUTH_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:3000

DATA_DIR=/data
UPLOAD_MAX_BYTES=2147483648
UPLOAD_RETENTION_DAYS=0

REDIS_URL=redis://redis:6379
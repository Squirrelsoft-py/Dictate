# Per-deployment overrides for docker-compose.yml.
# Every variable here has a default in compose via ${VAR:-default} syntax,
# so this file is OPTIONAL — copy and edit only what you need to change.
# Suggested: secrets, custom ports, host-specific URLs.

# ─── Public URL the browser uses to reach the API (auth + CORS origin) ──
BETTER_AUTH_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:3000

# ─── Auth (REQUIRED — generate with: openssl rand -hex 32) ──────────────
BETTER_AUTH_SECRET=change-me-please-change-me-please

# ─── Cloud provider API keys (fill only what you use; leave blank otherwise) ─
OPENAI_API_KEY=
GROQ_API_KEY=
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── OpenAI-compatible LLM endpoint (MiniMax, Ollama, OpenRouter, etc.) ─
# Any service speaking the OpenAI Chat Completions schema.
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# ─── Custom ports (if 3000/3001/9000 conflict on the host) ──────────────
# WEB_PORT=3000
# API_PORT=3001
# ASR_PORT=9000

# ─── Custom image tags / private registry (defaults are latest on GHCR) ─
# WEB_IMAGE=ghcr.io/squirrelsoft-py/dictate-web:latest
# API_IMAGE=ghcr.io/squirrelsoft-py/dictate-api:latest
# WORKER_IMAGE=ghcr.io/squirrelsoft-py/dictate-worker:latest
# ASR_IMAGE=onerahmet/openai-whisper-asr-webservice:latest

# ─── Provider overrides (rare — UI lets you pick per upload) ───────────
# ADMIN_ASR_PROVIDER=local
# ADMIN_DIARIZATION_PROVIDER=local
# ADMIN_LLM_PROVIDER=openai-compat

# ─── Whisper sidecar tuning (only if you swap the bundled model) ────────
# ASR_MODEL=large-v3
# ASR_ENGINE=openai_whisper
# ASR_DIARIZATION=true

# ─── Upload limits (only if you need to change them) ───────────────────
# UPLOAD_MAX_BYTES=2147483648
# UPLOAD_RETENTION_DAYS=0

# ─── Storage path (only if you bind-mount /data from the host) ─────────
# DATA_DIR=/data
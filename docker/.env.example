# Per-deployment overrides for docker-compose.yml.
# Every variable has a default inline in compose via ${VAR:-default},
# so this file is OPTIONAL — copy to .env and edit only what you need.

# ─── Public URLs the browser uses to reach the API ──────────────────
BETTER_AUTH_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:3000

# ─── Auth (REQUIRED — generate with: openssl rand -hex 32) ────────────
BETTER_AUTH_SECRET=change-me-please-please-please

# ─── Cloud provider API keys (fill only what you use) ───────────────
# If set, the asr sidecar is unused — set ADMIN_ASR_PROVIDER to
# one of these and remove the asr service from docker-compose.yml.
OPENAI_API_KEY=
GROQ_API_KEY=
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── OpenAI-compatible LLM endpoint (MiniMax, Ollama, OpenRouter) ───
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# ─── Custom ports (only if 3000/3001/9000 conflict on the host) ─────
# WEB_PORT=3000
# API_PORT=3001
# ASR_PORT=9000

# ─── Custom image tags / private registry ───────────────────────────
# WEB_IMAGE=ghcr.io/squirrelsoft-py/dictate-web:latest
# API_IMAGE=ghcr.io/squirrelsoft-py/dictate-api:latest
# WORKER_IMAGE=ghcr.io/squirrelsoft-py/dictate-worker:latest
# ASR_IMAGE=onerahmet/openai-whisper-asr-webservice:latest

# ─── Provider overrides (rare — UI lets you pick per upload) ─────────
# ADMIN_ASR_PROVIDER=local
# ADMIN_DIARIZATION_PROVIDER=local
# ADMIN_LLM_PROVIDER=openai-compat

# ─── Whisper sidecar tuning ─────────────────────────────────────────
# tiny | base | small | medium | large-v3
#   large-v3: best quality, ~6 GB RAM, slow without GPU
#   small:     good for meetings/lectures, ~1 GB RAM
#   tiny:      very fast, noticeably worse on real audio
# ASR_MODEL=large-v3

# Memory cap on the asr container. Needs ~7 GB for large-v3 on CPU.
# ASR_MEMORY_LIMIT=8G

# Enable diarization via the asr sidecar (requires whisperx engine
# + HF_TOKEN for pyannote). To use a separate diarization provider,
# set this to false and ADMIN_DIARIZATION_PROVIDER=deepgram.
# ASR_DIARIZATION=true
# HF_TOKEN=